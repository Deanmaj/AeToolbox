<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="6.0"
  ExtensionBundleId="com.aetoolbox"
  ExtensionBundleVersion="1.0.0"
  ExtensionBundleName="AE Toolbox">

  <ExtensionList>
    <Extension Id="com.aetoolbox.panel" Version="1.0.0"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <Host Name="AEFT" Version="[16.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="9.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.aetoolbox.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./host.jsx</ScriptPath>
          <CEFCommandLine/>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>AE Toolbox</Menu>
          <Geometry>
            <Size>
              <Height>540</Height>
              <Width>280</Width>
            </Size>
            <MinSize>
              <Height>300</Height>
              <Width>220</Width>
            </MinSize>
          </Geometry>
          <Icons/>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>

</ExtensionManifest>
